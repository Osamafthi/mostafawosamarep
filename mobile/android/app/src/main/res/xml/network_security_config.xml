<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Dev: cleartext HTTP to local API. Use HTTPS only in production. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
