APP_NAME="Ecommerce API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Base URL of the customer-facing PHP storefront (served by XAMPP on
# :80). Used by CustomerAuthController@verify to redirect the browser
# back to /views/customer/verify-email.php after the user clicks the
# emailed verification link.
FRONTEND_URL=http://localhost/mostafawosama

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=Ecommerce
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

# Storefront catalog cache (categories, product listings, product detail).
# Leave CATALOG_CACHE_STORE blank to reuse CACHE_STORE above; set to `redis`
# in production if you want the catalog on Redis while everything else stays
# on the default store. Flip CATALOG_CACHE_ENABLED=false to bypass the cache.
CATALOG_CACHE_ENABLED=true
CATALOG_CACHE_STORE=
CATALOG_CACHE_TTL_CATEGORIES=600
CATALOG_CACHE_TTL_LIST=60
CATALOG_CACHE_TTL_SHOW=300

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@ecommerce.local"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS="admin@ecommerce.local"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SANCTUM_STATEFUL_DOMAINS=

VITE_APP_NAME="${APP_NAME}"
